<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="750.0" prefWidth="1300.0" stylesheets="@../styles/userStyle.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.UsersController">
   <top>
      <MenuBar stylesheets="@../styles/menuStyle.css" BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="File">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#handleExit" text="Exit" />
            </items>
          </Menu>
          
          <Menu mnemonicParsing="false" text="Format">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#handleFontSize" text="Font Size" />
              <MenuItem mnemonicParsing="false" onAction="#handleFontFamily" text="Font Family" />
              <MenuItem mnemonicParsing="false" onAction="#handleTheme" text="Background Color" />
            </items>
          </Menu>
          
          <Menu mnemonicParsing="false" text="Help">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#handleAbout" text="About App" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
   <left>
      <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" spacing="10.0">
               <VBox.margin>
                  <Insets bottom="30.0" top="20.0" />
               </VBox.margin>
               <children>
                  <Label styleClass="logo-text" text="GHADS" />
                  <Label alignment="CENTER" styleClass="logo-subtext" text="Gaza Humanitarian Aid&#10;Distribution System" textAlignment="CENTER" />
               </children>
            </VBox>
            
            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#openDashboard" prefHeight="45.0" prefWidth="220.0" styleClass="sidebar-btn" text="🏠  Dashboard" />
                  <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#openOrganizations" prefHeight="45.0" prefWidth="220.0" styleClass="sidebar-btn" text="🏢  Organizations" />
                  <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#openUsers" prefHeight="45.0" prefWidth="220.0" styleClass="sidebar-btn-active" text="👤  Users" />
                  <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#openFamilies" prefHeight="45.0" prefWidth="220.0" styleClass="sidebar-btn" text="👪 Families" />
                  <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#openAidDistribution" prefHeight="45.0" prefWidth="220.0" styleClass="sidebar-btn" text="📦  Aid Distribution" />
                  <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#openChangePassword" prefHeight="45.0" prefWidth="220.0" styleClass="sidebar-btn" text="🔒  Change Password" />
               </children>
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </VBox>
            
            <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#handleLogout" prefHeight="45.0" prefWidth="220.0" styleClass="sidebar-btn" text="🚪  Logout">
               <VBox.margin>
                  <Insets bottom="20.0" left="10.0" right="10.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </left>
   
   <center>
      <VBox styleClass="main-content" BorderPane.alignment="CENTER">
         <children>
            
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" styleClass="top-bar">
               <children>
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="page-title" text="Users Management" />
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                           <children>
                              <Label style="-fx-text-fill: gray; -fx-font-size: 15;" text="Dashboard" />
                              <Label style="-fx-text-fill: gray; -fx-font-size: 12px;" text="&gt;" />
                              <Label style="-fx-text-fill: #003366; -fx-font-size: 18; -fx-font-weight: bold;" text="Users" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Button mnemonicParsing="false" styleClass="top-icon-btn" text="🔔" />
                        <HBox alignment="CENTER" spacing="8.0" styleClass="profile-box">
                           <children>
                              <Circle fill="#003366" radius="21.0" stroke="TRANSPARENT" />
                              <VBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label fx:id="lblUserName" prefHeight="20.0" prefWidth="144.0" style="-fx-font-weight: bold; -fx-font-size: 17;" text="System Admin" />
                                    <Label style="-fx-text-fill: gray; -fx-font-size: 13;" text="Administrator" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </HBox>
               </children>
               <VBox.margin>
                  <Insets bottom="15.0" />
               </VBox.margin>
            </HBox>
            
            <VBox styleClass="content-card">
               <children>
                  <GridPane hgap="40.0" vgap="10.0">
                     <columnConstraints>
                        <ColumnConstraints percentWidth="15.0" />
                        <ColumnConstraints percentWidth="37.0" />
                        <ColumnConstraints percentWidth="17.0" />
                        <ColumnConstraints percentWidth="31.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="35.0" />
                        <RowConstraints minHeight="35.0" />
                        <RowConstraints minHeight="35.0" />
                        <RowConstraints minHeight="35.0" />
                     </rowConstraints>
                     <children>
                        <Label styleClass="input-label" text="Full Name" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtFullName" promptText="Enter full name..." styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label styleClass="input-label" text="Username" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="txtUsername" promptText="Enter username..." styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label styleClass="input-label" text="Email" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <HBox alignment="CENTER_LEFT" styleClass="input-with-icon" GridPane.columnIndex="1" GridPane.rowIndex="2">
                           <children>
                              <TextField fx:id="txtEmail" promptText="Enter email address..." styleClass="transparent-field" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        
                        <Label styleClass="input-label" text="Password" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <HBox alignment="CENTER_LEFT" styleClass="input-with-icon" GridPane.columnIndex="1" GridPane.rowIndex="3">
                           <children>
                              <PasswordField fx:id="txtPassword" promptText="Enter password..." styleClass="transparent-field" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        
                        <Label styleClass="input-label" text="Role" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <ComboBox fx:id="cmbRole" prefWidth="300.0" promptText="Select role..." styleClass="form-input" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                        
                        <Label prefHeight="18.0" prefWidth="141.0" styleClass="input-label" text="Organization" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <ComboBox fx:id="cmbOrganization" prefWidth="300.0" promptText="Select organization..." styleClass="form-input" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                     </children>
                  </GridPane>
                  
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                     <children>
                        <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#handleAddUser" styleClass="btn-primary" text="➕ Add User" />
                        <Button fx:id="btnUpdate" mnemonicParsing="false" onAction="#handleUpdateUser" styleClass="btn-secondary" text="📝 Update" />
                        <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#handleDeleteUser" styleClass="btn-delete" text="🗑 Delete" />
                        <Button fx:id="btnClear" mnemonicParsing="false" onAction="#handleClear" styleClass="btn-secondary" text="🧹 Clear" />
                        <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                           <children>
                              <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-refresh" text="🔄 Refresh" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
               </children>
               <VBox.margin>
                  <Insets bottom="15.0" />
               </VBox.margin>
            </VBox>
            
            <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <TextField fx:id="txtSearch" onKeyReleased="#handleSearch" prefWidth="280.0" promptText="🔍 Search users..." styleClass="search-input" />
                     </children>
                  </HBox>
                  
                  <TableView fx:id="usersTable" prefHeight="200.0" styleClass="custom-table" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colUserId" prefWidth="60.0" text="ID" />
                      <TableColumn fx:id="colFullName" prefWidth="220.0" text="Full Name" />
                      <TableColumn fx:id="colUsername" prefWidth="130.0" text="Username" />
                      <TableColumn fx:id="colEmail" prefWidth="220.0" text="Email" />
                      <TableColumn fx:id="colRole" prefWidth="130.0" text="Role" />
                      <TableColumn fx:id="colOrganization" prefWidth="250.0" text="Organization" />
                    </columns>
                     <VBox.margin>
                        <Insets top="12.0" />
                     </VBox.margin>
                  </TableView>
               </children>
            </VBox>
            
         </children>
         <padding>
            <Insets bottom="15.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
